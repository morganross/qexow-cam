{
  "name": "qexow-cam",
  "version": "2.1.31",
  "private": true,
  "description": "Qexow CAM — local agent registry and message bus.",
  "type": "module",
  "bin": {
    "cam": "./bin/cam.js"
  },
  "scripts": {
    "doctor": "node ./bin/cam.js doctor",
    "daemon": "node ./bin/cam.js daemon start",
    "test:smoke": "node ./scripts/smoke-local.js",
    "test:strict-contract": "node ./scripts/verify-strict-contract.mjs",
    "build": "node scripts/refuse-local-build.mjs",
    "build:installer-payload": "node scripts/build-installer-payload.mjs",
    "purge-standalone-exes": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/purge-standalone-exes.ps1",
    "watch-workspace-exes": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/watch-workspace-exes.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "postject": "^1.0.0-alpha.6"
  },
  "dependencies": {
    "systray2": "^2.1.4"
  }
}
