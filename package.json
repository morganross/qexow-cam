{
  "name": "qexow-cam-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "React Electron desktop GUI for Qexow CAM",
  "main": "gui/electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron gui/electron/main.cjs\"",
    "build": "vite build",
    "start": "electron gui/electron/main.cjs",
    "prepare:cam-bin": "node gui/electron/prepare-cam-binary.cjs",
    "package:win": "cargo build --release && npm run build && npm run prepare:cam-bin && electron-builder --win portable --x64"
  },
  "build": {
    "appId": "com.qexow.cam",
    "productName": "Qexow CAM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "gui/electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "gui/resources/bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "Qexow-CAM-${version}-Windows-${arch}.${ext}"
    }
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  }
}
