{
  "name": "codex-agent-manager",
  "version": "0.1.0",
  "private": true,
  "description": "Local Codex app-server-backed agent registry and message bus.",
  "type": "module",
  "bin": {
    "cam": "./bin/cam.js"
  },
  "scripts": {
    "doctor": "node ./bin/cam.js doctor",
    "daemon": "node ./bin/cam.js daemon start",
    "test:smoke": "node ./scripts/smoke-local.js",
    "build": "pkg . -t node18-win-x64 --out-path dist"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
